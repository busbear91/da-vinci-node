# === Supabase ===
NEXT_PUBLIC_SUPABASE_URL=https://yourproject.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # server only — never prefix with NEXT_PUBLIC_

# === Cloudflare Tunnel URLs (one per laptop / per model) ===
# Each model is hosted on a different laptop running Ollama + cloudflared.
# The five models cover the five jailbreak attack categories — see lib/model-config.ts.
OLLAMA_URL_QWEN2=https://qwen2.yourdomain.com
OLLAMA_URL_PHI4=https://phi4.yourdomain.com
OLLAMA_URL_GEMMA2=https://gemma2.yourdomain.com
OLLAMA_URL_LLAMA3=https://llama3.yourdomain.com
OLLAMA_URL_MISTRAL=https://mistral.yourdomain.com

# === Response filter ===
# Server-side leak guard. The real reactor-code secrets live in Supabase
# (model_config table, RLS-locked). This env list is a second-line net in
# case a new secret is added at runtime and hasn't been seeded yet.
RESPONSE_FILTER_SECRETS=

# === Admin ===
# Comma-separated list of Supabase user IDs (uuids) with admin access.
ADMIN_USER_IDS=
